{
  "name": "cortex-plugin-crypto-accounting",
  "version": "1.0.1",
  "description": "Crypto Accounting & Tax \u2014 Track on-chain transactions, calculate cost basis, generate crypto tax reports (Form 8949)",
  "kind": "esm",
  "entryPoint": "mod.ts",
  "runtime": "deno",
  "author": "CortexPrism",
  "license": "MIT",
  "repository": "https://github.com/CortexPrism/cortex-plugin-crypto-accounting",
  "homepage": "https://cortexprism.io/marketplace/plugins/crypto-accounting",
  "capabilities": [
    "tools",
    "network:fetch"
  ],
